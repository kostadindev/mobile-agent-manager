\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces MobileAgents input modes. (a)\nonbreakingspace Multimodal: text, camera, and microphone all active. (b)\nonbreakingspace Text + Images: camera available but voice disabled. (c)\nonbreakingspace Voice-only: full-screen recording interface; responses are played back via TTS. All three modes unify into the same planning prompt.}}{4}{figure.caption.6}\protected@file@percent }
\newlabel{fig:chat}{{2}{4}{MobileAgents input modes. (a)~Multimodal: text, camera, and microphone all active. (b)~Text + Images: camera available but voice disabled. (c)~Voice-only: full-screen recording interface; responses are played back via TTS. All three modes unify into the same planning prompt}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces The three transparency configurations and the C3 execution DAG. (a)\nonbreakingspace Black Box: final answer only, no plan or graph. (b)\nonbreakingspace Plan Preview: task plan card with Execute/Cancel before agents run. (c)\nonbreakingspace Full Transparency: plan card plus live DAG. (d)\nonbreakingspace DAG close-up showing orchestrator, agent step nodes, animated edges, and a checkpoint gate before the Slack send step.}}{4}{figure.caption.8}\protected@file@percent }
\newlabel{fig:configs}{{3}{4}{The three transparency configurations and the C3 execution DAG. (a)~Black Box: final answer only, no plan or graph. (b)~Plan Preview: task plan card with Execute/Cancel before agents run. (c)~Full Transparency: plan card plus live DAG. (d)~DAG close-up showing orchestrator, agent step nodes, animated edges, and a checkpoint gate before the Slack send step}{figure.caption.8}{}}
