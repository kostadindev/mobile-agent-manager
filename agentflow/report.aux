\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Agent management screens. (a)\nonbreakingspace The Agents tab lists the orchestrator (always active) and all registered worker agents with per-agent enable/disable toggles. (b)\nonbreakingspace Tapping the orchestrator opens its detail sheet, showing goal, tools, system prompt, and the editable constitution field. (c)\nonbreakingspace A worker agent card shows its goal, tool names, and full system prompt backstory.}}{16}{figure.caption.28}\protected@file@percent }
\newlabel{fig:ss-agents}{{5}{16}{Agent management screens. (a)~The Agents tab lists the orchestrator (always active) and all registered worker agents with per-agent enable/disable toggles. (b)~Tapping the orchestrator opens its detail sheet, showing goal, tools, system prompt, and the editable constitution field. (c)~A worker agent card shows its goal, tool names, and full system prompt backstory}{figure.caption.28}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Settings and localisation screens. (a)\nonbreakingspace Settings exposes all three transparency modes, input modes (Multimodal / Text+Images / Voice Only), theme (Dark/Light/Auto), and language (EN/AR/ZH/BG). (b)\nonbreakingspace Bulgarian localisation: the full UI---including navigation labels and suggested queries---renders in Bulgarian with full RTL support for Arabic (not shown).}}{16}{figure.caption.29}\protected@file@percent }
\newlabel{fig:ss-settings}{{6}{16}{Settings and localisation screens. (a)~Settings exposes all three transparency modes, input modes (Multimodal / Text+Images / Voice Only), theme (Dark/Light/Auto), and language (EN/AR/ZH/BG). (b)~Bulgarian localisation: the full UI---including navigation labels and suggested queries---renders in Bulgarian with full RTL support for Arabic (not shown)}{figure.caption.29}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Slack integration and in-app documentation. (a)\nonbreakingspace Result of a Slack send step after checkpoint approval: two arXiv paper summaries posted to \#general by the agentflow bot. (b)\nonbreakingspace The Docs tab provides an in-app guide covering input modes, transparency modes, the agents tab, and execution graph; it is available without leaving the app.}}{17}{figure.caption.30}\protected@file@percent }
\newlabel{fig:ss-docs}{{7}{17}{Slack integration and in-app documentation. (a)~Result of a Slack send step after checkpoint approval: two arXiv paper summaries posted to \#general by the agentflow bot. (b)~The Docs tab provides an in-app guide covering input modes, transparency modes, the agents tab, and execution graph; it is available without leaving the app}{figure.caption.30}{}}
